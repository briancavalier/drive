  "findings": [
    {
      "level": "blocking",
      "title": "git rev-parse fallback returns invalid SHA",
      "details": "The new gitRevParse error handling swallows non-zero exits and returns whatever stdout contained (scripts/process-review.mjs:26-43). When git emits the requested ref name on stdout for an invalid revision, the function now returns that ref string instead of throwing. handlePass then forwards this value as FACTORY_LAST_READY_SHA (scripts/process-review.mjs:261-269), so an invalid SHA can be recorded for ready-for-review metadata. Example: `git rev-parse invalid-ref-name` exits 128 but prints `invalid-ref-name` on stdout, which would now be treated as a commit id.",
      "scope": "scripts/process-review.mjs",
      "recommendation": "Restore fail-fast behavior or validate that stdout contains a 40-character SHA before returning it from gitRevParse."
    }
  ]
